---
import "../styles/global.css";

// URL local de la API.
// Más adelante la moveremos a variable de entorno para Vercel/producción.
const apiUrl = "http://localhost:5083";
---

<html lang="es">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <title>Registro | Kim Scheduler</title>
        <meta name="description" content="Crear cuenta en Kim Scheduler." />
    </head>

    <body>
        <main
            class="relative flex min-h-screen items-center justify-center overflow-hidden px-4 py-10"
        >
            <!-- Fondo decorativo suave. Solo es visual, no afecta la lógica. -->
            <div class="pointer-events-none fixed inset-0 -z-10 opacity-50">
                <div
                    class="absolute -left-24 -top-24 h-80 w-80 rounded-full bg-[var(--ks-secondary-soft)] blur-3xl"
                >
                </div>
                <div
                    class="absolute -bottom-24 -right-24 h-80 w-80 rounded-full bg-[var(--ks-primary-soft)] blur-3xl"
                >
                </div>
            </div>

            <section class="w-full max-w-md">
                <header class="mb-6 text-center">
                    <a
                        href="/"
                        class="text-3xl font-bold tracking-tight text-[var(--ks-primary)]"
                    >
                        Kim Scheduler
                    </a>

                    <p class="mt-2 text-sm text-[var(--ks-text-muted)]">
                        Tu socio en la gestión del día a día
                    </p>
                </header>

                <article
                    class="ks-card-shadow rounded-[1.75rem] border border-[var(--ks-border)] bg-[var(--ks-surface)] p-6 md:p-8"
                >
                    <div class="mb-6">
                        <h1 class="text-2xl font-bold text-[var(--ks-text)]">
                            Crear una cuenta
                        </h1>

                        <p
                            class="mt-2 text-sm leading-6 text-[var(--ks-text-muted)]"
                        >
                            Completa tus datos para registrarte en Kim
                            Scheduler.
                        </p>
                    </div>

<!-- Aviso importante:
     El usuario no elige su rol.
     Si es el primer usuario del sistema, será Admin.
     Si ya existen usuarios, será Staff. -->
<div class="mb-6 rounded-2xl border border-[var(--ks-border)] bg-[var(--ks-surface-soft)] p-4">
  <p class="text-sm font-bold text-[var(--ks-text)]">
    Rol asignado automáticamente
  </p>

  <p class="mt-1 text-sm leading-6 text-[var(--ks-text-muted)]">
    Si eres el primer usuario del sistema, tu cuenta será Admin. Si ya existen usuarios, iniciarás como Staff.
  </p>
</div>

                    <form id="registerForm" class="space-y-4">
                        <label class="block">
                            <span
                                class="mb-1 block text-sm font-semibold text-[var(--ks-text)]"
                            >
                                Nombre completo
                            </span>

                            <input
                                id="fullNameInput"
                                class="w-full rounded-xl border border-[var(--ks-border)] bg-[var(--ks-surface-soft)] px-4 py-3 text-sm outline-none transition focus:border-[var(--ks-primary)] focus:bg-[var(--ks-surface)]"
                                type="text"
                                placeholder="Ej. Martin Mendoza"
                                required
                            />
                        </label>

                        <label class="block">
                            <span
                                class="mb-1 block text-sm font-semibold text-[var(--ks-text)]"
                            >
                                Correo electrónico
                            </span>

                            <input
                                id="emailInput"
                                class="w-full rounded-xl border border-[var(--ks-border)] bg-[var(--ks-surface-soft)] px-4 py-3 text-sm outline-none transition focus:border-[var(--ks-primary)] focus:bg-[var(--ks-surface)]"
                                type="email"
                                placeholder="martin@ejemplo.com"
                                required
                            />
                        </label>

                        <label class="block">
                            <span
                                class="mb-1 block text-sm font-semibold text-[var(--ks-text)]"
                            >
                                Contraseña
                            </span>

                            <div class="relative">
                                <input
                                    id="passwordInput"
                                    class="w-full rounded-xl border border-[var(--ks-border)] bg-[var(--ks-surface-soft)] px-4 py-3 pr-24 text-sm outline-none transition focus:border-[var(--ks-primary)] focus:bg-[var(--ks-surface)]"
                                    type="password"
                                    placeholder="Mínimo 6 caracteres"
                                    required
                                />

                                <button
                                    id="togglePasswordButton"
                                    class="absolute right-2 top-1/2 -translate-y-1/2 rounded-full px-3 py-1 text-xs font-bold text-[var(--ks-secondary)] hover:bg-[var(--ks-surface-muted)]"
                                    type="button"
                                >
                                    Mostrar
                                </button>
                            </div>
                        </label>

                        <!-- Requisitos visuales para ayudar al usuario.
                 El backend todavía exige mínimo 6 caracteres.
                 Más adelante podemos endurecer la regla en backend y frontend. -->
                        <div
                            class="rounded-2xl border border-[var(--ks-border)] bg-[var(--ks-surface-soft)] p-4"
                        >
                            <p class="text-sm font-bold text-[var(--ks-text)]">
                                La contraseña debe tener:
                            </p>

                            <ul
                                class="mt-3 space-y-2 text-sm text-[var(--ks-text-muted)]"
                            >
                                <li id="lengthRequirement">
                                    ○ Al menos 6 caracteres
                                </li>
                                <li id="uppercaseRequirement">
                                    ○ Una letra mayúscula recomendada
                                </li>
                                <li id="numberRequirement">
                                    ○ Un número recomendado
                                </li>
                            </ul>
                        </div>

                        <!-- Aquí mostraremos errores o éxito sin recargar la página. -->
                        <div
                            id="formMessage"
                            class="hidden rounded-2xl border p-4 text-sm leading-6"
                        >
                        </div>

                        <button
                            class="w-full rounded-full bg-[var(--ks-primary)] px-5 py-3 text-sm font-bold text-white transition hover:bg-[var(--ks-secondary)]"
                            type="submit"
                        >
                            Registrarse
                        </button>
                    </form>
                </article>

                <p class="mt-6 text-center text-sm text-[var(--ks-text-muted)]">
                    ¿Ya tienes una cuenta?
                    <a
                        href="/login"
                        class="font-bold text-[var(--ks-primary)] hover:underline"
                    >
                        Inicia sesión aquí
                    </a>
                </p>
            </section>
        </main>

        <script>
            const apiUrl = "http://localhost:5083";

            // Referencias tipadas a elementos del formulario.
            // Esto ayuda a TypeScript a saber que estos elementos tienen propiedades como .value.
            const registerForm =
                document.querySelector<HTMLFormElement>("#registerForm");
            const fullNameInput =
                document.querySelector<HTMLInputElement>("#fullNameInput");
            const emailInput =
                document.querySelector<HTMLInputElement>("#emailInput");
            const passwordInput =
                document.querySelector<HTMLInputElement>("#passwordInput");
            const togglePasswordButton =
                document.querySelector<HTMLButtonElement>(
                    "#togglePasswordButton",
                );

            const formMessage =
                document.querySelector<HTMLDivElement>("#formMessage");

            const lengthRequirement =
                document.querySelector<HTMLLIElement>("#lengthRequirement");
            const uppercaseRequirement = document.querySelector<HTMLLIElement>(
                "#uppercaseRequirement",
            );
            const numberRequirement =
                document.querySelector<HTMLLIElement>("#numberRequirement");

            type RegisterResponse = {
                id: string;
                fullName: string;
                email: string;
                role: number;
                isActive: boolean;
                createdAtUtc: string;
            };

            type ApiErrorResponse = {
                message?: string;
            };

            // Muestra mensajes visuales para éxito o error.
            function showFormMessage(
                message: string,
                type: "success" | "error",
            ): void {
                if (!formMessage) return;

                formMessage.classList.remove("hidden");

                if (type === "success") {
                    formMessage.className =
                        "rounded-2xl border border-[var(--ks-primary-soft)] bg-[var(--ks-primary-soft)] p-4 text-sm leading-6 text-[var(--ks-primary)]";
                } else {
                    formMessage.className =
                        "rounded-2xl border border-red-200 bg-red-50 p-4 text-sm leading-6 text-red-700";
                }

                formMessage.textContent = message;
            }

            // Actualiza los requisitos visuales mientras el usuario escribe.
            // Esto no reemplaza validaciones del backend; solo mejora la experiencia.
            function updatePasswordRequirements(password: string): void {
                if (lengthRequirement) {
                    lengthRequirement.textContent =
                        password.length >= 6
                            ? "✓ Al menos 6 caracteres"
                            : "○ Al menos 6 caracteres";
                }

                if (uppercaseRequirement) {
                    uppercaseRequirement.textContent = /[A-Z]/.test(password)
                        ? "✓ Una letra mayúscula recomendada"
                        : "○ Una letra mayúscula recomendada";
                }

                if (numberRequirement) {
                    numberRequirement.textContent = /[0-9]/.test(password)
                        ? "✓ Un número recomendado"
                        : "○ Un número recomendado";
                }
            }

            passwordInput?.addEventListener("input", () => {
                updatePasswordRequirements(passwordInput.value);
            });

            // Permite mostrar/ocultar la contraseña sin cambiar su valor.
            togglePasswordButton?.addEventListener("click", () => {
                if (!passwordInput || !togglePasswordButton) return;

                const isPasswordVisible = passwordInput.type === "text";

                passwordInput.type = isPasswordVisible ? "password" : "text";
                togglePasswordButton.textContent = isPasswordVisible
                    ? "Mostrar"
                    : "Ocultar";
            });

            registerForm?.addEventListener("submit", async (event) => {
                // Evita que el navegador recargue la página al enviar el formulario.
                event.preventDefault();

                if (!fullNameInput || !emailInput || !passwordInput) {
                    showFormMessage(
                        "No se encontraron todos los campos del formulario.",
                        "error",
                    );
                    return;
                }

                // Este payload coincide con RegisterRequest del backend.
                // No mandamos role porque el backend asigna Staff automáticamente.
                const payload = {
                    fullName: fullNameInput.value.trim(),
                    email: emailInput.value.trim().toLowerCase(),
                    password: passwordInput.value,
                };

                try {
                    const response = await fetch(
                        `${apiUrl}/api/auth/register`,
                        {
                            method: "POST",
                            headers: {
                                "Content-Type": "application/json",
                            },
                            body: JSON.stringify(payload),
                        },
                    );

                    const data: RegisterResponse | ApiErrorResponse =
                        await response.json();

                    if (!response.ok) {
                        const errorData = data as ApiErrorResponse;
                        showFormMessage(
                            errorData.message ?? "No se pudo crear la cuenta.",
                            "error",
                        );

                        return;
                    }

                    const registeredUser = data as RegisterResponse;

                    showFormMessage(
                        `Cuenta creada correctamente para ${registeredUser.fullName}. Rol asignado: ${registeredUser.role}.`,
                        "success",
                    );

                    registerForm.reset();
                    updatePasswordRequirements("");
                } catch {
                    showFormMessage(
                        "No se pudo conectar con la API. Revisa que el backend esté corriendo.",
                        "error",
                    );
                }
            });
        </script>
    </body>
</html>
