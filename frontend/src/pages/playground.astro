---
// ASTRO FRONTMATTER (Renderizado en Servidor):
// Este bloque --- se ejecuta estrictamente en el servidor en cada render. 
// Aquí definimos HTML estático y enviamos variables iniciales.
import "../styles/global.css";

const apiUrl = "http://localhost:5083";
---

<html lang="es">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <title>Playground | Kim Scheduler</title>
    </head>

    <body>
        <main
            class="mx-auto flex min-h-screen w-full max-w-6xl flex-col gap-6 px-4 py-6 md:px-8"
        >
            <header
                class="flex flex-col gap-4 rounded-[1.5rem] border border-[var(--ks-border)] bg-[var(--ks-surface)] p-5 ks-card-shadow md:flex-row md:items-center md:justify-between"
            >
                <div>
                    <a
                        href="/"
                        class="text-sm font-semibold text-[var(--ks-secondary)] hover:text-[var(--ks-primary)]"
                    >
                        ← Volver a landing
                    </a>

                    <h1
                        class="mt-3 text-3xl font-bold tracking-tight text-[var(--ks-text)]"
                    >
                        Playground técnico
                    </h1>

                    <p class="mt-2 text-[var(--ks-text-muted)]">
                        Zona temporal para probar endpoints del backend durante
                        desarrollo.
                    </p>
                </div>

                <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
                <div
                    class="rounded-full bg-[var(--ks-primary-soft)] px-4 py-2 text-sm font-bold text-[var(--ks-primary)]"
                >
                    API local: {apiUrl}
                </div>

                <!-- Cierra sesión eliminando el JWT guardado en el navegador. -->
                <button
                    id="logoutButton"
                    class="rounded-full border border-[var(--ks-border)] bg-[var(--ks-surface)] px-4 py-2 text-sm font-bold text-[var(--ks-secondary)] hover:bg-[var(--ks-surface-soft)]"
                    type="button"
                >
                    Cerrar sesión
                </button>
            </div>
            </header>

            {/* 
              HTML ESTÁTICO (Estructura Base):
              Estas secciones y botones existen por defecto en el DOM al cargar la página.
              Los botones tienen IDs específicos para que los scripts clientes los controlen.
            */}
            <section class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
                <article
                    class="rounded-[1.5rem] border border-[var(--ks-border)] bg-[var(--ks-surface)] p-5 ks-card-shadow"
                >
                    <p class="text-sm font-bold text-[var(--ks-secondary)]">
                        Health check
                    </p>
                    <h2 class="mt-2 text-xl font-bold">
                        Conexión a base de datos
                    </h2>
                    <p
                        class="mt-2 text-sm leading-6 text-[var(--ks-text-muted)]"
                    >
                        Prueba si la API puede conectarse a MariaDB.
                    </p>

                    <button
                        id="checkDatabaseButton"
                        class="mt-5 w-full rounded-full bg-[var(--ks-primary)] px-4 py-3 text-sm font-bold text-white hover:bg-[var(--ks-secondary)]"
                    >
                        Probar conexión
                    </button>
                </article>

                <article class="rounded-[1.5rem] border border-[var(--ks-border)] bg-[var(--ks-surface)] p-5 ks-card-shadow">
                  <p class="text-sm font-bold text-[var(--ks-secondary)]">Autenticación</p>

                  <h2 class="mt-2 text-xl font-bold">Ver sesión actual</h2>

                  <p class="mt-2 text-sm leading-6 text-[var(--ks-text-muted)]">
                    Consulta el endpoint protegido GET /api/auth/me usando el JWT guardado.
                  </p>

                  <button
                    id="getCurrentUserButton"
                    class="mt-5 w-full rounded-full bg-[var(--ks-primary)] px-4 py-3 text-sm font-bold text-white hover:bg-[var(--ks-secondary)]"
                  >
                    Ver sesión
                  </button>
                </article>

                <article
                    class="rounded-[1.5rem] border border-[var(--ks-border)] bg-[var(--ks-surface)] p-5 ks-card-shadow"
                >
                    <p class="text-sm font-bold text-[var(--ks-secondary)]">
                        Negocios
                    </p>
                    <h2 class="mt-2 text-xl font-bold">Listar negocios</h2>
                    <p
                        class="mt-2 text-sm leading-6 text-[var(--ks-text-muted)]"
                    >
                        Obtiene los negocios guardados en MariaDB.
                    </p>

                    <button
                        id="getBusinessesButton"
                        class="mt-5 w-full rounded-full bg-[var(--ks-surface-soft)] px-4 py-3 text-sm font-bold text-[var(--ks-primary)] hover:bg-[var(--ks-primary-soft)]"
                    >
                        Ver negocios
                    </button>
                </article>

                <article class="rounded-[1.5rem] border border-[var(--ks-border)] bg-[var(--ks-surface)] p-5 ks-card-shadow">
                  <p class="text-sm font-bold text-[var(--ks-secondary)]">Limpieza de datos</p>
                  <h2 class="mt-2 text-xl font-bold">Desactivar negocios demo</h2>
                  <p class="mt-2 text-sm leading-6 text-[var(--ks-text-muted)]">
                    Oculta negocios creados por error usando soft delete.
                  </p>

                  <div class="mt-5 flex flex-col gap-3">
                    <button
                      id="deactivateBadBusinessButton"
                      class="w-full rounded-full bg-[var(--ks-accent-soft)] px-4 py-3 text-sm font-bold text-[var(--ks-accent)] hover:bg-[var(--ks-surface-soft)]"
                    >
                      Desactivar “Corte clásico”
                    </button>

                    <button
                      id="deactivateStringBusinessButton"
                      class="w-full rounded-full bg-[var(--ks-accent-soft)] px-4 py-3 text-sm font-bold text-[var(--ks-accent)] hover:bg-[var(--ks-surface-soft)]"
                    >
                      Desactivar “string”
                    </button>
                  </div>
                </article>

                <article class="rounded-[1.5rem] border border-[var(--ks-border)] bg-[var(--ks-surface)] p-5 ks-card-shadow">
                  <p class="text-sm font-bold text-[var(--ks-secondary)]">Negocios</p>

                  <h2 class="mt-2 text-xl font-bold">Crear negocio</h2>

                  <p class="mt-2 text-sm leading-6 text-[var(--ks-text-muted)]">
                    Crea un negocio activo en MariaDB usando el endpoint POST /api/businesses.
                  </p>

                  <!--
                    Este formulario es temporal para desarrollo.
                    Más adelante esta acción vivirá en /admin o en un panel protegido con login.
                  -->
                  <form id="createBusinessForm" class="mt-5 flex flex-col gap-3">
                    <label class="flex flex-col gap-1 text-sm font-semibold text-[var(--ks-text)]">
                      Nombre del negocio
                      <input
                        id="businessNameInput"
                        class="rounded-xl border border-[var(--ks-border)] bg-[var(--ks-surface-soft)] px-4 py-3 text-sm outline-none focus:border-[var(--ks-primary)]"
                        type="text"
                        placeholder="Barbería Nova"
                        required
                      />
                    </label>

                    <label class="flex flex-col gap-1 text-sm font-semibold text-[var(--ks-text)]">
                      Slug
                      <input
                        id="businessSlugInput"
                        class="rounded-xl border border-[var(--ks-border)] bg-[var(--ks-surface-soft)] px-4 py-3 text-sm outline-none focus:border-[var(--ks-primary)]"
                        type="text"
                        placeholder="barberia-nova"
                        required
                      />
                    </label>

                    <label class="flex flex-col gap-1 text-sm font-semibold text-[var(--ks-text)]">
                      Teléfono
                      <input
                        id="businessPhoneInput"
                        class="rounded-xl border border-[var(--ks-border)] bg-[var(--ks-surface-soft)] px-4 py-3 text-sm outline-none focus:border-[var(--ks-primary)]"
                        type="text"
                        placeholder="4629876543"
                      />
                    </label>

                    <label class="flex flex-col gap-1 text-sm font-semibold text-[var(--ks-text)]">
                      Email
                      <input
                        id="businessEmailInput"
                        class="rounded-xl border border-[var(--ks-border)] bg-[var(--ks-surface-soft)] px-4 py-3 text-sm outline-none focus:border-[var(--ks-primary)]"
                        type="email"
                        placeholder="contacto@barberianova.com"
                      />
                    </label>

                    <button
                      class="mt-2 rounded-full bg-[var(--ks-primary)] px-4 py-3 text-sm font-bold text-white hover:bg-[var(--ks-secondary)]"
                      type="submit"
                    >
                      Crear negocio
                    </button>
                  </form>
                </article>

                <article class="rounded-[1.5rem] border border-[var(--ks-border)] bg-[var(--ks-surface)] p-5 ks-card-shadow">
                  <p class="text-sm font-bold text-[var(--ks-secondary)]">Servicios</p>

                  <h2 class="mt-2 text-xl font-bold">Crear servicio</h2>

                  <p class="mt-2 text-sm leading-6 text-[var(--ks-text-muted)]">
                    Crea un servicio asociado a un negocio usando POST /api/services. Requiere Admin.
                  </p>

                  <form id="createServiceForm" class="mt-5 flex flex-col gap-3">
                    <label class="flex flex-col gap-1 text-sm font-semibold text-[var(--ks-text)]">
                      Negocio
                      <select
                        id="serviceBusinessIdInput"
                        class="rounded-xl border border-[var(--ks-border)] bg-[var(--ks-surface-soft)] px-4 py-3 text-sm outline-none focus:border-[var(--ks-primary)]"
                        required
                      >
                        <option value="">Cargando negocios...</option>
                      </select>
                    </label>

                    <label class="flex flex-col gap-1 text-sm font-semibold text-[var(--ks-text)]">
                      Nombre del servicio
                      <input
                        id="serviceNameInput"
                        class="rounded-xl border border-[var(--ks-border)] bg-[var(--ks-surface-soft)] px-4 py-3 text-sm outline-none focus:border-[var(--ks-primary)]"
                        type="text"
                        placeholder="Corte de cabello"
                        required
                      />
                    </label>

                    <label class="flex flex-col gap-1 text-sm font-semibold text-[var(--ks-text)]">
                      Descripción
                      <input
                        id="serviceDescriptionInput"
                        class="rounded-xl border border-[var(--ks-border)] bg-[var(--ks-surface-soft)] px-4 py-3 text-sm outline-none focus:border-[var(--ks-primary)]"
                        type="text"
                        placeholder="Corte clásico con tijera y máquina"
                      />
                    </label>

                    <div class="grid grid-cols-2 gap-3">
                      <label class="flex flex-col gap-1 text-sm font-semibold text-[var(--ks-text)]">
                        Duración (min)
                        <input
                          id="serviceDurationInput"
                          class="rounded-xl border border-[var(--ks-border)] bg-[var(--ks-surface-soft)] px-4 py-3 text-sm outline-none focus:border-[var(--ks-primary)]"
                          type="number"
                          min="1"
                          placeholder="30"
                          required
                        />
                      </label>

                      <label class="flex flex-col gap-1 text-sm font-semibold text-[var(--ks-text)]">
                        Precio ($)
                        <input
                          id="servicePriceInput"
                          class="rounded-xl border border-[var(--ks-border)] bg-[var(--ks-surface-soft)] px-4 py-3 text-sm outline-none focus:border-[var(--ks-primary)]"
                          type="number"
                          step="0.01"
                          min="0"
                          placeholder="15.00"
                          required
                        />
                      </label>
                    </div>

                    <button
                      class="mt-2 rounded-full bg-[var(--ks-primary)] px-4 py-3 text-sm font-bold text-white hover:bg-[var(--ks-secondary)]"
                      type="submit"
                    >
                      Crear servicio
                    </button>
                  </form>
                </article>

                <article
                    class="rounded-[1.5rem] border border-dashed border-[var(--ks-border)] bg-[var(--ks-surface-soft)] p-5"
                >
                    <p class="text-sm font-bold text-[var(--ks-text-muted)]">
                        Citas
                    </p>
                    <h2
                        class="mt-2 text-xl font-bold text-[var(--ks-text-muted)]"
                    >
                        Próximamente
                    </h2>
                    <p
                        class="mt-2 text-sm leading-6 text-[var(--ks-text-muted)]"
                    >
                        Aquí probaremos reservar, confirmar y cancelar citas.
                    </p>
                </article>
            </section>

            <section class="rounded-[1.5rem] border border-[var(--ks-border)] bg-[var(--ks-surface)] p-5 ks-card-shadow">
              <div class="flex flex-col gap-2 md:flex-row md:items-center md:justify-between">
                <div>
                  <h2 class="text-xl font-bold">Negocios activos</h2>
                  <p class="text-sm text-[var(--ks-text-muted)]">
                    Lista visual de negocios obtenidos desde MariaDB.
                  </p>
                </div>

                <button
                  id="refreshBusinessesButton"
                  class="rounded-full bg-[var(--ks-primary)] px-4 py-2 text-sm font-bold text-white hover:bg-[var(--ks-secondary)]"
                >
                  Actualizar lista
                </button>
              </div>

              {/* 
                HTML DINÁMICO (Contenedor):
                Este elemento contenedor inicia vacío o con un placeholder de carga.
                A través del script cliente, inyectaremos código HTML mapeado dinámicamente.
              */}
              <div
                id="businessesList"
                class="mt-5 grid gap-4 md:grid-cols-2"
              >
                <p class="text-sm text-[var(--ks-text-muted)]">
                  Presiona “Actualizar lista” para cargar negocios.
                </p>
              </div>
            </section>

            <section
                class="rounded-[1.5rem] border border-[var(--ks-border)] bg-[var(--ks-surface)] p-5 ks-card-shadow"
            >
                <div
                    class="flex flex-col gap-2 md:flex-row md:items-center md:justify-between"
                >
                    <div>
                        <h2 class="text-xl font-bold">Respuesta del backend</h2>
                        <p class="text-sm text-[var(--ks-text-muted)]">
                            Aquí verás el JSON que regrese la API.
                        </p>
                    </div>

                    <button
                        id="clearResultButton"
                        class="rounded-full border border-[var(--ks-border)] px-4 py-2 text-sm font-bold text-[var(--ks-secondary)] hover:bg-[var(--ks-surface-soft)]"
                    >
                        Limpiar
                    </button>
                </div>

                <pre
                    id="resultBox"
                    class="mt-5 min-h-40 overflow-auto rounded-2xl bg-[var(--ks-surface-soft)] p-4 text-sm text-[var(--ks-text)]">Sin respuesta todavía.</pre>
            </section>
        </main>

        <script>
            // CLIENT-SIDE SCRIPT: Este código se descarga y ejecuta enteramente en el navegador del cliente.
            const apiUrl = "http://localhost:5083";

            // Revisamos si existe un JWT guardado en localStorage.
            // Si no hay token, significa que el usuario no inició sesión.
            const storedToken = localStorage.getItem("kim_scheduler_token");

            // /playground es una herramienta interna de desarrollo.
            // Si el usuario no tiene token, lo mandamos a /login.
            if (!storedToken) {
              window.location.href = "/login";
            }

            // querySelector con Genéricos de TypeScript (<HTMLButtonElement> / <HTMLDivElement>):
            // Por defecto, querySelector retorna un tipo genérico 'Element' que carece de métodos específicos.
            // Al castearlo explícitamente, le enseñamos a TypeScript qué clase de objeto DOM es. Esto habilita:
            // 1. Validaciones del compilador (ej. TypeScript sabe que un HTMLButtonElement tiene una propiedad 'disabled').
            // 2. Autocompletado inteligente en el editor de código.
            const resultBox =
                document.querySelector<HTMLPreElement>("#resultBox");
            const checkDatabaseButton =
                document.querySelector<HTMLButtonElement>(
                    "#checkDatabaseButton",
                );
            const getBusinessesButton =
                document.querySelector<HTMLButtonElement>(
                    "#getBusinessesButton",
                );
            const clearResultButton =
                document.querySelector<HTMLButtonElement>("#clearResultButton");

            // Botón para probar si el JWT guardado permite consultar /api/auth/me.
            const getCurrentUserButton = document.querySelector<HTMLButtonElement>(
              "#getCurrentUserButton"
            );

            // Botón para cerrar sesión desde el playground.
            const logoutButton = document.querySelector<HTMLButtonElement>("#logoutButton");

            const deactivateBadBusinessButton = document.querySelector<HTMLButtonElement>(
                "#deactivateBadBusinessButton"
            );

            const deactivateStringBusinessButton = document.querySelector<HTMLButtonElement>(
                "#deactivateStringBusinessButton"
            );

            const refreshBusinessesButton = document.querySelector<HTMLButtonElement>(
                "#refreshBusinessesButton"
            );

            const businessesList = document.querySelector<HTMLDivElement>("#businessesList");

            // Referencias al formulario y sus campos.
            // Usamos tipos específicos para que TypeScript sepa qué propiedades existen,
            // por ejemplo .value en inputs y .reset() en formularios.
            const createBusinessForm = document.querySelector<HTMLFormElement>(
                "#createBusinessForm"
            );

            const businessNameInput = document.querySelector<HTMLInputElement>(
                "#businessNameInput"
            );

            const businessSlugInput = document.querySelector<HTMLInputElement>(
                "#businessSlugInput"
            );

            const businessPhoneInput = document.querySelector<HTMLInputElement>(
                "#businessPhoneInput"
            );

            const businessEmailInput = document.querySelector<HTMLInputElement>(
                "#businessEmailInput"
            );

            const createServiceForm = document.querySelector<HTMLFormElement>(
                "#createServiceForm"
            );

            const serviceBusinessIdInput = document.querySelector<HTMLSelectElement>(
                "#serviceBusinessIdInput"
            );

            const serviceNameInput = document.querySelector<HTMLInputElement>(
                "#serviceNameInput"
            );

            const serviceDescriptionInput = document.querySelector<HTMLInputElement>(
                "#serviceDescriptionInput"
            );

            const serviceDurationInput = document.querySelector<HTMLInputElement>(
                "#serviceDurationInput"
            );

            const servicePriceInput = document.querySelector<HTMLInputElement>(
                "#servicePriceInput"
            );

            type ApiResult = {
                statusCode: number;
                ok: boolean;
                data: unknown; // unknown vs any: 'unknown' es la alternativa segura a 'any' en TypeScript.
                               // Obliga al desarrollador a comprobar el tipo de dato (por ej. con Array.isArray)
                               // antes de acceder a sus propiedades, previniendo excepciones en tiempo de ejecución.
            };

            type Business = {
                id: string;
                name: string;
                slug: string;
                phone: string | null;
                email: string | null;
                isActive: boolean;
                createdAtUtc: string;
            };

            function showResult(data: unknown): void {
                if (!resultBox) return;

                resultBox.textContent = JSON.stringify(data, null, 2);
            }

            // HTML DINÁMICO (renderBusinesses):
            // Esta función borra el contenido del contenedor del DOM y construye dinámicamente tarjetas HTML
            // para cada negocio de la base de datos mapeando los objetos JS a strings utilizando Template Literals.
            function renderBusinesses(businesses: Business[]): void {
                if (!businessesList) return;

                if (serviceBusinessIdInput) {
                    if (businesses.length === 0) {
                        serviceBusinessIdInput.innerHTML = '<option value="">No hay negocios activos</option>';
                    } else {
                        serviceBusinessIdInput.innerHTML = businesses
                            .map(b => `<option value="${b.id}">${b.name} (${b.id.substring(0, 8)})</option>`)
                            .join("");
                    }
                }

                if (businesses.length === 0) {
                    businessesList.innerHTML = `
                        <p class="text-sm text-[var(--ks-text-muted)]">
                            No hay negocios activos todavía.
                        </p>
                    `;
                    return;
                }

                // data-business-id (Atributo de Datos Personalizado):
                // Permite guardar metadatos (como el UUID/ID de la base de datos de cada negocio)
                // directamente incrustados en la etiqueta HTML del botón.
                // Luego podemos recuperarlo en JS con 'element.dataset.businessId'.
                businessesList.innerHTML = businesses
                    .map(
                        (business) => `
                            <article class="rounded-2xl border border-[var(--ks-border)] bg-[var(--ks-surface-soft)] p-4">
                                <div class="flex items-start justify-between gap-3">
                                    <div>
                                        <h3 class="font-bold text-[var(--ks-text)]">
                                            ${business.name}
                                        </h3>
                                        <p class="mt-1 text-sm text-[var(--ks-text-muted)]">
                                            /${business.slug}
                                        </p>
                                    </div>

                                    <span class="rounded-full bg-[var(--ks-primary-soft)] px-3 py-1 text-xs font-bold text-[var(--ks-primary)]">
                                        Activo
                                    </span>
                                </div>

                                <div class="mt-4 space-y-1 text-sm text-[var(--ks-text-muted)]">
                                    <p>Tel: ${business.phone ?? "Sin teléfono"}</p>
                                    <p>Email: ${business.email ?? "Sin email"}</p>
                                </div>

                                <button
                                    class="deactivate-business-button mt-4 w-full rounded-full bg-[var(--ks-accent-soft)] px-4 py-2 text-sm font-bold text-[var(--ks-accent)] hover:bg-[var(--ks-surface)]"
                                    data-business-id="${business.id}"
                                >
                                    Desactivar negocio
                                </button>
                            </article>
                        `
                    )
                    .join("");
            }

            // ENLAZADO DINÁMICO DE EVENTOS (bindDeactivateBusinessButtons):
            // ¿Por qué llamarlo después de renderBusinesses?
            // Al inyectar código dinámicamente con innerHTML, los botones ".deactivate-business-button"
            // NO existen en el DOM al cargar la página. Si intentáramos enlazarlos al inicio, querySelectorAll
            // devolvería una lista vacía. Debemos llamar a bindDeactivateBusinessButtons justo después de 
            // pintar las tarjetas para encontrar estos botones recién añadidos al DOM y enlazarles el evento click.
            function bindDeactivateBusinessButtons(): void {
                const deactivateButtons = document.querySelectorAll<HTMLButtonElement>(
                    ".deactivate-business-button"
                );

                deactivateButtons.forEach((button) => {
                    button.addEventListener("click", async () => {
                        // Obtenemos el ID almacenado en la propiedad dataset (data-business-id) del HTML.
                        const businessId = button.dataset.businessId;

                        if (!businessId) {
                            showResult({
                                ok: false,
                                message: "No se encontró el ID del negocio.",
                            });
                            return;
                        }

                        try {
                            // LLAMADA HTTP PATCH (Soft Delete):
                            // Se ejecuta asíncronamente conectándose al endpoint del backend para inactivar el negocio.
                            const result = await requestJson(
                                `${apiUrl}/api/businesses/${businessId}/deactivate`,
                                {
                                    method: "PATCH",
                                }
                            );

                            showResult(result);

                            // Refresco de Datos Reactivo: Tras desactivar un comercio, llamamos de nuevo al backend
                            // para actualizar el listado visual sin recargar la página web.
                            const businessesResult = await requestJson(`${apiUrl}/api/businesses`);

                            if (Array.isArray(businessesResult.data)) {
                                renderBusinesses(businessesResult.data as Business[]);
                                bindDeactivateBusinessButtons(); // Re-enlazamos los clics a las tarjetas recién pintadas.
                            }
                        } catch {
                            showResult({
                                ok: false,
                                message: "No se pudo desactivar el negocio.",
                            });
                        }
                    });
                });
            }

            // API FETCH WRAPPER (requestJson):
            // Abstracción reutilizable del fetch nativo.
            // Simplifica las llamadas asíncronas encapsulando la extracción del body asíncrono y mapeando
            // cabeceras y métodos dinámicos (GET, POST, PATCH), centralizando la obtención del código de estado HTTP.
            async function requestJson(
                url: string,
                options?: RequestInit
            ): Promise<ApiResult> {
                const response = await fetch(url, options);
                const data: unknown = await response.json();

                return {
                    statusCode: response.status,
                    ok: response.ok,
                    data,
                };
            }

            // Lee el JWT guardado después del login.
            // Si el usuario no ha iniciado sesión, regresará null.
            function getAuthToken(): string | null {
              return localStorage.getItem("kim_scheduler_token");
            }

            // Construye headers para endpoints protegidos.
            // Authorization: Bearer {token} es lo que ASP.NET Core espera para validar JWT.
            function getAuthHeaders(): HeadersInit {
              const token = getAuthToken();

              if (!token) {
                return {
                  "Content-Type": "application/json",
                };
              }

              return {
                "Content-Type": "application/json",
                "Authorization": `Bearer ${token}`,
              };
            }

            // LISTENERS DE INTERACCIÓN CLIENTE:
            
            // 1. Health check de base de datos (petición GET de diagnóstico)
            checkDatabaseButton?.addEventListener("click", async () => {
                try {
                    const result = await requestJson(
                        `${apiUrl}/api/health/database`,
                    );
                    showResult(result);
                } catch {
                    showResult({
                        ok: false,
                        message:
                            "No se pudo conectar con la API. Revisa que el backend esté corriendo.",
                    });
                }
            });

            // 2. Consulta cruda de Negocios (GET /api/businesses)
            getBusinessesButton?.addEventListener("click", async () => {
                try {
                    const result = await requestJson(
                        `${apiUrl}/api/businesses`,
                    );
                    showResult(result);
                } catch {
                    showResult({
                        ok: false,
                        message: "No se pudo obtener la lista de negocios.",
                    });
                }
            });

            // 3. Consulta de Negocios y Renderizado Visual Dinámico en la interfaz
            refreshBusinessesButton?.addEventListener("click", async () => {
                try {
                    const result = await requestJson(`${apiUrl}/api/businesses`);

                    showResult(result);

                    if (Array.isArray(result.data)) {
                        renderBusinesses(result.data as Business[]);
                        bindDeactivateBusinessButtons(); // Indispensable llamar aquí para registrar clics en los nuevos botones dinámicos.
                    }
                } catch {
                    showResult({
                        ok: false,
                        message: "No se pudo actualizar la lista de negocios.",
                    });
                }
            });

            // 4. Envío del Formulario para Crear Negocio (POST /api/businesses)
            createBusinessForm?.addEventListener("submit", async (event) => {
                // Evita que el navegador recargue la página al enviar el formulario.
                event.preventDefault();

                // Validamos que existan los inputs antes de leer sus valores.
                // Esto evita errores si algún ID está mal escrito en el HTML.
                if (!businessNameInput || !businessSlugInput) {
                    showResult({
                        ok: false,
                        message: "No se encontraron los campos obligatorios del formulario.",
                    });
                    return;
                }

                // Creamos el objeto que espera el backend en CreateBusinessRequest.
                const payload = {
                    name: businessNameInput.value.trim(),
                    slug: businessSlugInput.value.trim().toLowerCase(),
                    phone: businessPhoneInput?.value.trim() || null,
                    email: businessEmailInput?.value.trim() || null,
                };

                // Crear negocio ya está protegido con [Authorize].
                // Si no hay token, avisamos antes de llamar al backend.
                if (!getAuthToken()) {
                  showResult({
                    ok: false,
                    message: "Necesitas iniciar sesión antes de crear negocios.",
                  });

                  return;
                }

                try {
                    // Enviamos el negocio al backend usando POST.
                    const result = await requestJson(`${apiUrl}/api/businesses`, {
                        method: "POST",

                        // Mandamos el JWT en Authorization para pasar [Authorize].
                        headers: getAuthHeaders(),

                        body: JSON.stringify(payload),
                    });

                    showResult(result);

                    // Si el backend respondió bien (ok = true), limpiamos los campos del formulario.
                    if (result.ok) {
                        createBusinessForm.reset();
                    }

                    // Después de crear, volvemos a pedir la lista actualizada del backend para refrescar las tarjetas.
                    const businessesResult = await requestJson(`${apiUrl}/api/businesses`);

                    if (Array.isArray(businessesResult.data)) {
                        renderBusinesses(businessesResult.data as Business[]);
                        bindDeactivateBusinessButtons(); // Reconectamos los botones de las nuevas tarjetas inyectadas dinámicamente.
                    }
                } catch {
                    showResult({
                        ok: false,
                        message: "No se pudo crear el negocio. Revisa que el backend esté corriendo.",
                    });
                }
            });

            createServiceForm?.addEventListener("submit", async (event) => {
                event.preventDefault();

                if (!serviceBusinessIdInput || !serviceNameInput || !serviceDurationInput || !servicePriceInput) {
                    showResult({
                        ok: false,
                        message: "No se encontraron los campos obligatorios del formulario de servicios.",
                    });
                    return;
                }

                const businessId = serviceBusinessIdInput.value;
                if (!businessId) {
                    showResult({
                        ok: false,
                        message: "Por favor selecciona un negocio.",
                    });
                    return;
                }

                const payload = {
                    businessId: businessId,
                    name: serviceNameInput.value.trim(),
                    description: serviceDescriptionInput?.value.trim() || null,
                    durationMinutes: parseInt(serviceDurationInput.value, 10),
                    price: parseFloat(servicePriceInput.value),
                };

                if (!getAuthToken()) {
                    showResult({
                        ok: false,
                        message: "Necesitas iniciar sesión antes de crear servicios.",
                    });
                    return;
                }

                try {
                    const result = await requestJson(`${apiUrl}/api/services`, {
                        method: "POST",
                        headers: getAuthHeaders(),
                        body: JSON.stringify(payload),
                    });

                    showResult(result);

                    if (result.ok) {
                        createServiceForm.reset();
                    }
                } catch {
                    showResult({
                        ok: false,
                        message: "No se pudo crear el servicio. Revisa que el backend esté corriendo.",
                    });
                }
            });

            // TODO: Estos dos manejadores usan IDs fijos con fines estrictos de testeo y pruebas manuales del backend.
            // Se dinamizarán o removerán en fases posteriores de desarrollo.
            deactivateBadBusinessButton?.addEventListener("click", async () => {
                try {
                    const result = await requestJson(
                        `${apiUrl}/api/businesses/2344f286-2bcc-496c-ae5f-8ba7b4139c6d/deactivate`,
                        {
                            method: "PATCH",
                        }
                    );

                    showResult(result);
                } catch {
                    showResult({
                        ok: false,
                        message: "No se pudo desactivar el negocio Corte clásico.",
                    });
                }
            });

            deactivateStringBusinessButton?.addEventListener("click", async () => {
                try {
                    const result = await requestJson(
                        `${apiUrl}/api/businesses/c0300f44-7001-4552-9c49-086c53387b00/deactivate`,
                        {
                            method: "PATCH",
                        }
                    );

                    showResult(result);
                } catch {
                    showResult({
                        ok: false,
                        message: "No se pudo desactivar el negocio string.",
                    });
                }
            });

            clearResultButton?.addEventListener("click", () => {
                if (!resultBox) return;

                resultBox.textContent = "Sin respuesta todavía.";
            });

            getCurrentUserButton?.addEventListener("click", async () => {
              try {
                // Este endpoint está protegido con [Authorize].
                // Por eso mandamos Authorization: Bearer {token}.
                const result = await requestJson(`${apiUrl}/api/auth/me`, {
                  method: "GET",
                  headers: getAuthHeaders(),
                });

                showResult(result);
              } catch {
                showResult({
                  ok: false,
                  message: "No se pudo obtener la sesión actual.",
                });
              }
            });

            logoutButton?.addEventListener("click", () => {
                // Eliminamos el token y los datos básicos del usuario.
                // Sin token, el usuario ya no puede entrar al playground ni usar endpoints protegidos.
                localStorage.removeItem("kim_scheduler_token");
                localStorage.removeItem("kim_scheduler_user");

                // Redirigimos al login para que pueda volver a autenticarse.
                window.location.href = "/login";
            });

            // Cargar negocios e iniciar selectores al abrir la página
            async function loadBusinesses(): Promise<void> {
                try {
                    const result = await requestJson(`${apiUrl}/api/businesses`);
                    if (Array.isArray(result.data)) {
                        renderBusinesses(result.data as Business[]);
                        bindDeactivateBusinessButtons();
                    }
                } catch (err) {
                    console.error("Error al cargar negocios:", err);
                }
            }

            loadBusinesses();
        </script>
    </body>
</html>
