		<footer
			class="border-t border-[var(--ks-border)] bg-[var(--ks-surface-soft)] px-4 py-12 md:px-8"
		>
			<div
				class="mx-auto flex w-full max-w-6xl flex-col gap-8 md:flex-row md:items-start md:justify-between"
			>
				<div>
					<p
						class="text-lg font-bold tracking-tight text-[var(--ks-primary)] flex items-center gap-2"
					>
						<span class="inline-block h-5 w-5 rounded bg-[var(--ks-primary)] text-white text-center leading-5 font-black text-xs">K</span>
						Kim Scheduler
					</p>
					<p
						class="mt-3 max-w-xs text-sm leading-6 text-[var(--ks-text-muted)]"
					>
						SaaS de gestión de citas para pequeños negocios locales.
						Proyecto open source en desarrollo.
					</p>
				</div>

				<div class="flex gap-16">
					<div>
						<p
							class="mb-4 text-xs font-bold uppercase tracking-wider text-[var(--ks-text)]"
						>
							Producto
						</p>
						<div
							class="flex flex-col gap-2 text-sm text-[var(--ks-text-muted)]"
						>
							<a
								href="#beneficios"
								class="transition hover:text-[var(--ks-primary)]"
								>Beneficios</a
							>
							<a
								href="#como-funciona"
								class="transition hover:text-[var(--ks-primary)]"
								>Cómo funciona</a
							>
						</div>
					</div>

					<div>
						<p
							class="mb-4 text-xs font-bold uppercase tracking-wider text-[var(--ks-text)]"
						>
							Cuenta
						</p>
						<div
							class="flex flex-col gap-2 text-sm text-[var(--ks-text-muted)]"
						>
							<a
								href="/register"
								class="transition hover:text-[var(--ks-primary)]"
								>Crear cuenta</a
							>
							<a
								href="/login"
								class="transition hover:text-[var(--ks-primary)]"
								>Iniciar sesión</a
							>
						</div>
					</div>
				</div>
			</div>

			<div
				class="mx-auto mt-8 flex w-full max-w-6xl border-t border-[var(--ks-border)] pt-6"
			>
				<p class="text-xs text-[var(--ks-text-muted)]">
					© 2026 Kim Scheduler. Proyecto open source en desarrollo.
				</p>
			</div>
		</footer>

		<script>
			// Datos de simulación por industria
			const industriesData = {
				barber: {
					name: "Barbería Nova",
					appointments: [
						{ id: "b1", title: "Corte clásico", customer: "Martín P.", time: "10:00 AM", status: "Pendiente", badgeClass: "bg-[var(--ks-surface-soft)] text-[var(--ks-text-muted)]" },
						{ id: "b2", title: "Corte + barba", customer: "Jorge S.", time: "12:30 PM", status: "Confirmada", badgeClass: "bg-[var(--ks-primary-soft)] text-[var(--ks-primary)] font-bold" },
						{ id: "b3", title: "Afeitado premium", customer: "Luis A.", time: "03:00 PM", status: "Confirmada", badgeClass: "bg-[var(--ks-primary-soft)] text-[var(--ks-primary)] font-bold" }
					],
					services: [
						"Corte clásico",
						"Corte + barba",
						"Afeitado premium",
						"Tinte capilar"
					]
				},
				spa: {
					name: "Estética Glam",
					appointments: [
						{ id: "s1", title: "Manicura Spa", customer: "Sofia V.", time: "09:00 AM", status: "Confirmada", badgeClass: "bg-[var(--ks-primary-soft)] text-[var(--ks-primary)] font-bold" },
						{ id: "s2", title: "Corte de dama", customer: "Elena R.", time: "11:15 AM", status: "Pendiente", badgeClass: "bg-[var(--ks-surface-soft)] text-[var(--ks-text-muted)]" },
						{ id: "s3", title: "Tinte + Peinado", customer: "Ana G.", time: "02:00 PM", status: "Confirmada", badgeClass: "bg-[var(--ks-primary-soft)] text-[var(--ks-primary)] font-bold" }
					],
					services: [
						"Manicura Spa",
						"Corte de dama",
						"Tinte + Peinado",
						"Pedicura"
					]
				},
				dental: {
					name: "Consultorio Dental",
					appointments: [
						{ id: "d1", title: "Limpieza Dental", customer: "Daniel M.", time: "08:30 AM", status: "Confirmada", badgeClass: "bg-[var(--ks-primary-soft)] text-[var(--ks-primary)] font-bold" },
						{ id: "d2", title: "Consulta Diagnóstico", customer: "Marcela F.", time: "10:30 AM", status: "Pendiente", badgeClass: "bg-[var(--ks-surface-soft)] text-[var(--ks-text-muted)]" },
						{ id: "d3", title: "Ortodoncia Control", customer: "Roberto G.", time: "04:30 PM", status: "Confirmada", badgeClass: "bg-[var(--ks-primary-soft)] text-[var(--ks-primary)] font-bold" }
					],
					services: [
						"Limpieza Dental",
						"Consulta Diagnóstico",
						"Ortodoncia Control",
						"Blanqueamiento"
					]
				}
			};

			let currentIndustry = 'barber';
			const localAppointments = JSON.parse(JSON.stringify(industriesData)); // copia profunda

			// Referencias de elementos del simulador
			const businessNameEl = document.getElementById('simulator-business-name');
			const citasCountEl = document.getElementById('simulator-citas-count');
			const appointmentsListEl = document.getElementById('simulator-appointments-list');
			const simulatorFormContainer = document.getElementById('booking-simulator');
			const simulatorForm = document.getElementById('simulator-form') as HTMLFormElement | null;
			const simCustomerNameInput = document.getElementById('sim-customer-name') as HTMLInputElement | null;
			const simServiceSelect = document.getElementById('sim-service') as HTMLSelectElement | null;
			const simTimeSelect = document.getElementById('sim-time') as HTMLSelectElement | null;
			
			const btnOpenSim = document.getElementById('btn-open-simulator');
			const btnCancelSim = document.getElementById('btn-cancel-sim');

			// Botones de industria
			const btnBarber = document.getElementById('industry-barber');
			const btnSpa = document.getElementById('industry-spa');
			const btnDental = document.getElementById('industry-dental');

			function renderSimulator() {
				const data = localAppointments[currentIndustry];
				
				// Renderizar nombre e info
				if (businessNameEl) businessNameEl.textContent = data.name;
				
				const count = data.appointments.length;
				if (citasCountEl) citasCountEl.textContent = `${count} ${count === 1 ? 'cita' : 'citas'} hoy`;

				// Renderizar citas
				if (appointmentsListEl) {
					appointmentsListEl.innerHTML = '';
					if (data.appointments.length === 0) {
						appointmentsListEl.innerHTML = `<div class="text-center py-6 text-xs text-[var(--ks-text-muted)]">Sin citas programadas</div>`;
					} else {
						data.appointments.forEach((app: any) => {
							const item = document.createElement('div');
							item.className = 'rounded-xl bg-[var(--ks-surface)] p-3 border border-[var(--ks-border)] transition-all hover:shadow-sm flex items-center justify-between fade-in-scale';
							item.innerHTML = `
								<div>
									<p class="text-xs font-bold text-[var(--ks-text)]">${app.title}</p>
									<p class="text-[10px] text-[var(--ks-text-muted)] mt-0.5">${app.time} · Cliente: ${app.customer}</p>
								</div>
								<span class="rounded-full px-2 py-0.5 text-[10px] ${app.badgeClass}">
									${app.status}
								</span>
							`;
							appointmentsListEl.appendChild(item);
						});
					}
				}

				// Rellenar servicios del selector
				if (simServiceSelect) {
					simServiceSelect.innerHTML = '';
					data.services.forEach((srv: string) => {
						const opt = document.createElement('option');
						opt.value = srv;
						opt.textContent = srv;
						simServiceSelect.appendChild(opt);
					});
				}
			}

			function switchIndustry(industryId: string, activeBtn: HTMLElement | null) {
				currentIndustry = industryId;
				
				// Resetear estilos de botones
				document.querySelectorAll('.industry-btn').forEach(btn => {
					btn.className = 'industry-btn flex-1 rounded-lg py-1.5 text-xs font-bold transition-all text-[var(--ks-text-muted)] hover:text-[var(--ks-text)]';
				});

				// Activar el actual
				if (activeBtn) {
					activeBtn.className = 'industry-btn flex-1 rounded-lg py-1.5 text-xs font-bold transition-all bg-[var(--ks-surface)] text-[var(--ks-primary)] shadow-sm';
				}

				// Cerrar simulador por si estuviera abierto
				closeSimulatorForm();
				
				renderSimulator();
			}

			function openSimulatorForm() {
				if (simulatorFormContainer) {
					simulatorFormContainer.classList.remove('max-h-0', 'opacity-0');
					simulatorFormContainer.classList.add('max-h-[300px]', 'opacity-100');
					if (simCustomerNameInput) simCustomerNameInput.focus();
				}
			}

			function closeSimulatorForm() {
				if (simulatorFormContainer) {
					simulatorFormContainer.classList.add('max-h-0', 'opacity-0');
					simulatorFormContainer.classList.remove('max-h-[300px]', 'opacity-100');
					if (simulatorForm) simulatorForm.reset();
				}
			}

			// Configurar eventos
			btnBarber?.addEventListener('click', () => switchIndustry('barber', btnBarber));
			btnSpa?.addEventListener('click', () => switchIndustry('spa', btnSpa));
			btnDental?.addEventListener('click', () => switchIndustry('dental', btnDental));

			btnOpenSim?.addEventListener('click', () => {
				if (simulatorFormContainer?.classList.contains('opacity-100')) {
					closeSimulatorForm();
				} else {
					openSimulatorForm();
				}
			});

			btnCancelSim?.addEventListener('click', closeSimulatorForm);

			simulatorForm?.addEventListener('submit', (e) => {
				e.preventDefault();
				const name = simCustomerNameInput?.value || 'Anónimo';
				const service = simServiceSelect?.value || 'Servicio';
				const time = simTimeSelect?.value || '12:00 PM';

				// Añadir nueva cita al inicio
				localAppointments[currentIndustry].appointments.unshift({
					id: 'sim-' + Date.now(),
					title: service,
					customer: name,
					time: time,
					status: 'Confirmada',
					badgeClass: 'bg-[var(--ks-primary-soft)] text-[var(--ks-primary)] font-bold'
				});

				closeSimulatorForm();
				renderSimulator();

				// Resaltar primer elemento recién agregado
				const firstItem = appointmentsListEl?.firstElementChild;
				if (firstItem) {
					firstItem.classList.add('pulse-new-item');
					setTimeout(() => firstItem.classList.remove('pulse-new-item'), 2000);
				}
			});

			// FAQ Accordion
			const faqItems = document.querySelectorAll('.faq-item');
			faqItems.forEach(item => {
				item.addEventListener('click', () => {
					const content = item.querySelector('.faq-content') as HTMLElement | null;
					const icon = item.querySelector('.faq-icon');
					const isOpen = content?.classList.contains('open');

					// Cerrar otros
					document.querySelectorAll('.faq-content').forEach(c => {
						const htmlC = c as HTMLElement;
						htmlC.classList.remove('open');
						htmlC.style.maxHeight = "";
					});
					document.querySelectorAll('.faq-icon').forEach(i => {
						i.classList.remove('open');
						i.textContent = '+';
					});

					// Abrir el actual si no estaba abierto
					if (!isOpen && content && icon) {
						content.classList.add('open');
						content.style.maxHeight = content.scrollHeight + 'px';
						icon.classList.add('open');
						icon.textContent = '−';
					}
				});
			});

			// Cargar estado inicial
			renderSimulator();
		</script>
	</body>
</html>

<style>
	/* Patrón de cuadrícula de puntos */
	.dot-grid-pattern {
		background-image: radial-gradient(var(--ks-primary-muted) 1.2px, transparent 1.2px);
		background-size: 20px 20px;
		opacity: 0.08;
	}

	/* Animaciones de entrada */
	@keyframes fade-in-up {
		from {
			opacity: 0;
			transform: translateY(24px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@keyframes float-slow {
		0%,
		100% {
			transform: translateY(0);
		}
		50% {
			transform: translateY(-30px);
		}
	}

	@keyframes float-reverse {
		0%,
		100% {
			transform: translateY(0);
		}
		50% {
			transform: translateY(30px);
		}
	}

	.animate-fade-in-up {
		animation: fade-in-up 0.7s ease-out both;
	}

	.animate-fade-in-up-delayed {
		animation: fade-in-up 0.7s ease-out 0.2s both;
	}

	.animate-float-slow {
		animation: float-slow 8s ease-in-out infinite;
	}

	.animate-float-reverse {
		animation: float-reverse 10s ease-in-out infinite;
	}

	@keyframes fadeInScale {
		from {
			opacity: 0;
			transform: scale(0.95);
		}
		to {
			opacity: 1;
			transform: scale(1);
		}
	}

	.fade-in-scale {
		animation: fadeInScale 0.25s ease-out forwards;
	}

	@keyframes pulseNewItem {
		0% {
			background-color: var(--ks-primary-soft);
			border-color: var(--ks-primary);
		}
		100% {
			background-color: var(--ks-surface);
			border-color: var(--ks-border);
		}
	}

	.pulse-new-item {
		animation: pulseNewItem 2s ease-out forwards;
	}
</style>
