---
import "../styles/global.css";

const benefits = [
	{
		title: "Fácil de usar",
		description:
			"Una interfaz clara para que cualquier negocio pueda gestionar citas sin curva de aprendizaje complicada.",
		icon: "calendar",
	},
	{
		title: "Pensado para negocios locales",
		description:
			"Ideal para barberías, estéticas, consultorios, spas y servicios que trabajan con horarios.",
		icon: "store",
	},
	{
		title: "Preparado para crecer",
		description:
			"Base lista para futuras integraciones con Telegram, IA, recordatorios y panel administrativo.",
		icon: "rocket",
	},
];

const steps = [
	{
		number: "01",
		title: "Crea tu negocio",
		description: "Registra tu negocio local con nombre, slug único y datos de contacto.",
	},
	{
		number: "02",
		title: "Configura servicios",
		description: "Define los servicios que ofreces, duración y precio de cada uno.",
	},
	{
		number: "03",
		title: "Recibe citas",
		description: "Tus clientes reservan en línea y tú gestionas todo desde un solo lugar.",
	},
];

const stats = [
	{ value: "5", label: "Tablas en la base de datos" },
	{ value: "4", label: "Endpoints activos" },
	{ value: "100%", label: "Open source" },
	{ value: "JWT", label: "Autenticación segura" },
];
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>Kim Scheduler — Gestión de citas para negocios locales</title>
		<meta
			name="description"
			content="SaaS de gestión de citas para pequeños negocios locales. Simplifica tu agenda con una herramienta clara y escalable."
		/>
	</head>

	<body>
		<!-- Fondo decorativo global con círculos difuminados y patrón de puntos -->
		<div class="pointer-events-none fixed inset-0 -z-10 overflow-hidden opacity-40">
			<div class="dot-grid-pattern absolute inset-0"></div>
			<div
				class="animate-float-slow absolute -left-32 -top-32 h-[600px] w-[600px] rounded-full bg-[var(--ks-secondary-soft)] blur-[130px] opacity-60"
			>
			</div>
			<div
				class="animate-float-reverse absolute -bottom-32 -right-32 h-[600px] w-[600px] rounded-full bg-[var(--ks-primary-soft)] blur-[130px] opacity-60"
			>
			</div>
			<div
				class="animate-float-slow absolute left-1/2 top-1/3 h-[400px] w-[400px] -translate-x-1/2 rounded-full bg-[var(--ks-accent-soft)] opacity-20 blur-[110px]"
			>
			</div>
		</div>

		<header
			class="sticky top-0 z-50 border-b border-[var(--ks-border)] bg-[var(--ks-background)]/85 backdrop-blur-md"
		>
			<nav
				class="mx-auto flex h-16 w-full max-w-6xl items-center justify-between px-4 md:px-8"
			>
				<a
					href="/"
					class="text-lg font-bold tracking-tight text-[var(--ks-primary)] flex items-center gap-2 hover:opacity-90 transition"
				>
					<span class="inline-block h-6 w-6 rounded-lg bg-[var(--ks-primary)] text-white text-center leading-6 font-black text-sm">K</span>
					Kim Scheduler
				</a>

				<div class="hidden items-center gap-6 md:flex">
					<a
						href="#beneficios"
						class="text-sm font-medium text-[var(--ks-text-muted)] transition hover:text-[var(--ks-primary)]"
					>
						Beneficios
					</a>

					<a
						href="#como-funciona"
						class="text-sm font-medium text-[var(--ks-text-muted)] transition hover:text-[var(--ks-primary)]"
					>
						Cómo funciona
					</a>

					<!-- Link público para iniciar sesión. -->
					<a
						href="/login"
						class="text-sm font-medium text-[var(--ks-text-muted)] transition hover:text-[var(--ks-primary)]"
					>
						Iniciar sesión
					</a>

					<!-- Botón principal para crear cuenta. -->
					<a
						href="/register"
						class="rounded-full bg-[var(--ks-primary)] px-4 py-2 text-sm font-semibold text-white transition hover:bg-[var(--ks-secondary)] shadow-sm hover:shadow"
					>
						Crear cuenta
					</a>
				</div>

				<a
					href="/login"
					class="rounded-full bg-[var(--ks-primary)] px-4 py-2 text-sm font-semibold text-white md:hidden shadow-sm"
				>
					Entrar
				</a>
			</nav>
		</header>

		<main>
			<!-- Hero Section -->
			<section
				class="mx-auto grid min-h-[calc(100vh-4rem)] w-full max-w-6xl items-center gap-12 px-4 py-16 md:grid-cols-[1.1fr_0.9fr] md:px-8 md:py-20"
			>
				<div class="animate-fade-in-up">
					<p
						class="mb-4 inline-flex items-center gap-2 rounded-full border border-[var(--ks-border)] bg-[var(--ks-surface)] px-4 py-2 text-xs font-bold uppercase tracking-wider text-[var(--ks-secondary)]"
					>
						<span
							class="inline-block h-2 w-2 animate-pulse rounded-full bg-[var(--ks-primary)]"
						></span>
						Gestión de citas simplificada
					</p>

					<h1
						class="max-w-3xl text-4xl font-black tracking-tight text-[var(--ks-text)] sm:text-5xl md:text-6xl leading-[1.1]"
					>
						Simplifica la
						<span class="text-[var(--ks-primary)] underline decoration-wavy decoration-[var(--ks-primary-soft)] underline-offset-8">agenda</span>
						de tu negocio local
					</h1>

					<p
						class="mt-6 max-w-2xl text-lg leading-8 text-[var(--ks-text-muted)]"
					>
						Gestiona citas, servicios y horarios desde un solo
						lugar. Una herramienta simple, clara y preparada para
						crecer contigo.
					</p>

					<div class="mt-8 flex flex-col gap-3 sm:flex-row">
						<a
							href="/register"
							class="inline-flex items-center justify-center gap-2 rounded-full bg-[var(--ks-primary)] px-8 py-4 text-sm font-bold text-white transition hover:bg-[var(--ks-secondary)] hover:shadow-lg"
						>
							Crear cuenta gratis
							<span class="text-base">→</span>
						</a>

						<a
							href="/login"
							class="inline-flex items-center justify-center rounded-full border border-[var(--ks-border)] bg-[var(--ks-surface)] px-8 py-4 text-sm font-bold text-[var(--ks-secondary)] transition hover:bg-[var(--ks-surface-soft)]"
						>
							Iniciar sesión
						</a>
					</div>

					<!-- Mini stats bajo los CTAs -->
					<div
						class="mt-10 flex flex-wrap gap-6 border-t border-[var(--ks-border)] pt-8"
					>
						<div>
							<p
								class="text-2xl font-bold text-[var(--ks-primary)]"
							>
								100%
							</p>
							<p class="text-xs text-[var(--ks-text-muted)]">
								Gratis y open source
							</p>
						</div>
						<div>
							<p
								class="text-2xl font-bold text-[var(--ks-primary)]"
							>
								JWT
							</p>
							<p class="text-xs text-[var(--ks-text-muted)]">
								Autenticación segura
							</p>
						</div>
						<div>
							<p
								class="text-2xl font-bold text-[var(--ks-primary)]"
							>
								REST
							</p>
							<p class="text-xs text-[var(--ks-text-muted)]">
								API moderna
							</p>
						</div>
					</div>
				</div>

				<!-- Card preview con animación de entrada y simulador interactivo -->
				<div class="animate-fade-in-up-delayed">
					<div
						class="ks-card-shadow rounded-[2rem] border border-[var(--ks-border)] bg-[var(--ks-surface)] p-4 md:p-5 relative overflow-hidden"
					>
						<!-- Efecto de brillo sutil en esquina -->
						<div class="absolute -right-20 -top-20 w-40 h-40 bg-[var(--ks-primary-soft)] rounded-full blur-2xl opacity-40 pointer-events-none"></div>
						
						<div
							class="rounded-[1.5rem] bg-[var(--ks-surface-soft)] p-4 sm:p-5 relative z-10"
						>
							<!-- Selector de industrias / Segmented control -->
							<div class="mb-5 flex rounded-xl bg-[var(--ks-surface-muted)] p-1">
								<button id="industry-barber" class="industry-btn flex-1 rounded-lg py-1.5 text-xs font-bold transition-all bg-[var(--ks-surface)] text-[var(--ks-primary)] shadow-sm">
									Barbería
								</button>
								<button id="industry-spa" class="industry-btn flex-1 rounded-lg py-1.5 text-xs font-bold transition-all text-[var(--ks-text-muted)] hover:text-[var(--ks-text)]">
									Estética
								</button>
								<button id="industry-dental" class="industry-btn flex-1 rounded-lg py-1.5 text-xs font-bold transition-all text-[var(--ks-text-muted)] hover:text-[var(--ks-text)]">
									Dental
								</button>
							</div>

							<div class="mb-5 flex items-center justify-between">
								<div>
									<p
										id="simulator-business-name"
										class="text-xs font-bold uppercase tracking-wider text-[var(--ks-primary)]"
									>
										Barbería Nova
									</p>
									<h2
										id="simulator-citas-count"
										class="mt-0.5 text-2xl font-black text-[var(--ks-text)]"
									>
										3 citas hoy
									</h2>
								</div>

								<span
									class="inline-flex items-center gap-1.5 rounded-full bg-[var(--ks-primary-soft)] px-3 py-1 text-xs font-bold text-[var(--ks-primary)]"
								>
									<span class="h-1.5 w-1.5 rounded-full bg-[var(--ks-primary)] animate-pulse"></span>
									Simulador
								</span>
							</div>

							<!-- Simulador de reserva (Formulario interactivo oculto por defecto) -->
							<div id="booking-simulator" class="max-h-0 overflow-hidden transition-all duration-300 ease-in-out opacity-0">
								<div class="mb-4 rounded-2xl border border-[var(--ks-primary-soft)] bg-[var(--ks-surface)] p-4 shadow-sm">
									<h3 class="text-xs font-bold text-[var(--ks-primary)] mb-2 uppercase tracking-wide">Programar nueva cita</h3>
									<form id="simulator-form" class="space-y-3">
										<div>
											<label class="block text-[10px] font-bold text-[var(--ks-text-muted)] uppercase mb-1">Nombre del cliente</label>
											<input type="text" id="sim-customer-name" placeholder="Ej. Carlos Mendoza" class="w-full rounded-xl border border-[var(--ks-border)] bg-[var(--ks-surface-soft)] px-3 py-2 text-xs outline-none focus:border-[var(--ks-primary)] focus:bg-[var(--ks-surface)] transition" required />
										</div>
										<div class="grid grid-cols-2 gap-2">
											<div>
												<label class="block text-[10px] font-bold text-[var(--ks-text-muted)] uppercase mb-1">Servicio</label>
												<select id="sim-service" class="w-full rounded-xl border border-[var(--ks-border)] bg-[var(--ks-surface-soft)] px-2 py-2 text-xs outline-none focus:border-[var(--ks-primary)] focus:bg-[var(--ks-surface)] transition">
													<!-- Llenado dinámico -->
												</select>
											</div>
											<div>
												<label class="block text-[10px] font-bold text-[var(--ks-text-muted)] uppercase mb-1">Hora</label>
												<select id="sim-time" class="w-full rounded-xl border border-[var(--ks-border)] bg-[var(--ks-surface-soft)] px-2 py-2 text-xs outline-none focus:border-[var(--ks-primary)] focus:bg-[var(--ks-surface)] transition">
													<option value="09:00 AM">09:00 AM</option>
													<option value="11:30 AM">11:30 AM</option>
													<option value="01:00 PM">01:00 PM</option>
													<option value="03:30 PM">03:30 PM</option>
													<option value="06:00 PM">06:00 PM</option>
												</select>
											</div>
										</div>
										<div class="flex gap-2 pt-1">
											<button type="button" id="btn-cancel-sim" class="flex-1 rounded-xl border border-[var(--ks-border)] py-2 text-xs font-bold text-[var(--ks-text-muted)] hover:bg-[var(--ks-surface-soft)] transition">
												Cancelar
											</button>
											<button type="submit" class="flex-1 rounded-xl bg-[var(--ks-primary)] py-2 text-xs font-bold text-white hover:bg-[var(--ks-secondary)] transition shadow-sm">
												Agregar
											</button>
										</div>
									</form>
								</div>
							</div>

							<!-- Lista de citas del simulador -->
							<div id="simulator-appointments-list" class="space-y-2.5 max-h-[260px] overflow-y-auto pr-1">
								<!-- Se cargará dinámicamente según la industria seleccionada -->
							</div>

							<!-- Botón de Simular Nueva Cita -->
							<button id="btn-open-simulator" class="mt-4 flex w-full items-center justify-center gap-2 rounded-xl border border-dashed border-[var(--ks-primary-muted)] bg-[var(--ks-surface)] py-2.5 text-xs font-bold text-[var(--ks-primary)] hover:bg-[var(--ks-primary-soft)] hover:border-transparent transition-all shadow-sm">
								<span>+ Simular reserva en vivo</span>
							</button>
						</div>
					</div>
				</div>
			</section>

			<!-- Stats Section (Premium style) -->
			<section class="relative -mt-8 z-20 mx-auto max-w-6xl px-4 md:px-8">
				<div class="ks-card-shadow rounded-[2rem] border border-[var(--ks-border)] bg-[var(--ks-surface)]/80 backdrop-blur p-8 md:p-10">
					<div class="grid grid-cols-2 gap-8 md:grid-cols-4 divide-y-0 divide-x-0 sm:divide-y-0 md:divide-x divide-[var(--ks-border)]">
						{
							stats.map((stat, idx) => (
								<div class={`text-center ${idx > 0 ? 'md:pl-4' : ''}`}>
									<p class="text-4xl font-extrabold tracking-tight text-[var(--ks-primary)] transition-transform hover:scale-105 inline-block cursor-default">
										{stat.value}
									</p>
									<p class="mt-2 text-xs font-bold uppercase tracking-wider text-[var(--ks-text-muted)]">
										{stat.label}
									</p>
								</div>
							))
						}
					</div>
				</div>
			</section>

			<!-- Beneficios -->
			<section
				id="beneficios"
				class="mx-auto w-full max-w-6xl px-4 py-24 md:px-8"
			>
				<div class="mb-16 text-center animate-fade-in-up">
					<p
						class="mb-3 inline-flex rounded-full border border-[var(--ks-border)] bg-[var(--ks-surface)] px-4 py-2 text-xs font-bold uppercase tracking-wider text-[var(--ks-secondary)]"
					>
						¿Por qué Kim Scheduler?
					</p>
					<h2
						class="text-3xl font-bold tracking-tight text-[var(--ks-text)] md:text-5xl"
					>
						Diseñado para operar sin complicaciones
					</h2>
					<p
						class="mx-auto mt-4 max-w-2xl text-base leading-7 text-[var(--ks-text-muted)]"
					>
						Kim Scheduler empieza simple, pero está pensado para
						convertirse en una plataforma SaaS escalable y veloz.
					</p>
				</div>

				<div class="grid gap-8 md:grid-cols-3">
					{
						benefits.map((benefit) => (
							<article class="group ks-card-shadow rounded-[2rem] border border-[var(--ks-border)] bg-[var(--ks-surface)] p-8 transition-all hover:-translate-y-1.5 hover:border-[var(--ks-primary-muted)] hover:shadow-xl duration-300">
								<div class="mb-6 flex h-14 w-14 items-center justify-center rounded-2xl bg-[var(--ks-primary-soft)] transition-colors duration-300 group-hover:bg-[var(--ks-primary)] group-hover:text-white">
									{benefit.icon === "calendar" && (
										<svg
											class="h-6 w-6 text-[var(--ks-primary)] transition-colors duration-300 group-hover:text-white"
											fill="none"
											viewBox="0 0 24 24"
											stroke="currentColor"
											stroke-width="2"
										>
											<path
												stroke-linecap="round"
												stroke-linejoin="round"
												d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
											/>
										</svg>
									)}
									{benefit.icon === "store" && (
										<svg
											class="h-6 w-6 text-[var(--ks-primary)] transition-colors duration-300 group-hover:text-white"
											fill="none"
											viewBox="0 0 24 24"
											stroke="currentColor"
											stroke-width="2"
										>
											<path
												stroke-linecap="round"
												stroke-linejoin="round"
												d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z"
											/>
										</svg>
									)}
									{benefit.icon === "rocket" && (
										<svg
											class="h-6 w-6 text-[var(--ks-primary)] transition-colors duration-300 group-hover:text-white"
											fill="none"
											viewBox="0 0 24 24"
											stroke="currentColor"
											stroke-width="2"
										>
											<path
												stroke-linecap="round"
												stroke-linejoin="round"
												d="M13 10V3L4 14h7v7l9-11h-7z"
											/>
										</svg>
									)}
								</div>

								<h3 class="text-2xl font-bold text-[var(--ks-text)]">
									{benefit.title}
								</h3>

								<p class="mt-4 text-sm leading-6 text-[var(--ks-text-muted)]">
									{benefit.description}
								</p>
							</article>
						))
					}
				</div>
			</section>

			<!-- Cómo funciona -->
			<section
				id="como-funciona"
				class="border-y border-[var(--ks-border)] bg-[var(--ks-surface-soft)]"
			>
				<div class="mx-auto w-full max-w-6xl px-4 py-24 md:px-8">
					<div class="mb-16 text-center">
						<p
							class="mb-3 inline-flex rounded-full border border-[var(--ks-border)] bg-[var(--ks-surface)] px-4 py-2 text-xs font-bold uppercase tracking-wider text-[var(--ks-secondary)]"
						>
							3 pasos simples
						</p>
						<h2
							class="text-3xl font-bold tracking-tight text-[var(--ks-text)] md:text-5xl"
						>
							Cómo funciona el flujo
						</h2>
						<p
							class="mx-auto mt-4 max-w-2xl text-base leading-7 text-[var(--ks-text-muted)]"
						>
							Empieza a gestionar las citas de tus clientes en minutos. Sin
							configuraciones complejas.
						</p>
					</div>

					<div class="relative grid gap-8 md:grid-cols-3">
						<!-- Línea de conexión decorativa en desktop -->
						<div class="absolute left-0 right-0 top-1/2 hidden h-0.5 -translate-y-1/2 border-t-2 border-dashed border-[var(--ks-primary-muted)]/30 z-0 md:block max-w-[75%] mx-auto"></div>
						
						{
							steps.map((step) => (
								<div class="relative z-10 rounded-[1.5rem] border border-[var(--ks-border)] bg-[var(--ks-surface)] p-8 transition-all hover:-translate-y-1 hover:border-[var(--ks-primary-muted)] hover:shadow-lg duration-300">
									<div class="mb-5 flex h-14 w-14 items-center justify-center rounded-full bg-[var(--ks-primary-soft)] text-2xl font-black text-[var(--ks-primary)]">
										{step.number}
									</div>

									<h3 class="text-xl font-bold text-[var(--ks-text)]">
										{step.title}
									</h3>

									<p class="mt-3 text-sm leading-6 text-[var(--ks-text-muted)]">
										{step.description}
									</p>
								</div>
							))
						}
					</div>
				</div>
			</section>

			<!-- Preguntas Frecuentes (FAQ) Section -->
			<section class="mx-auto w-full max-w-4xl px-4 py-24 md:px-8">
				<div class="mb-16 text-center">
					<p
						class="mb-3 inline-flex rounded-full border border-[var(--ks-border)] bg-[var(--ks-surface)] px-4 py-2 text-xs font-bold uppercase tracking-wider text-[var(--ks-secondary)]"
					>
						Preguntas Frecuentes
					</p>
					<h2
						class="text-3xl font-bold tracking-tight text-[var(--ks-text)] md:text-5xl"
					>
						Resolvemos tus dudas
					</h2>
					<p
						class="mx-auto mt-4 max-w-xl text-sm leading-6 text-[var(--ks-text-muted)]"
					>
						Todo lo que necesitas saber sobre el funcionamiento de la agenda y la configuración del sistema.
					</p>
				</div>

				<div class="space-y-4">
					<div class="faq-item border border-[var(--ks-border)] bg-[var(--ks-surface)] rounded-2xl p-5 cursor-pointer transition-all hover:border-[var(--ks-primary-muted)]">
						<div class="flex items-center justify-between">
							<h4 class="font-bold text-[var(--ks-text)] pr-4 text-sm md:text-base">¿Kim Scheduler es gratuito?</h4>
							<span class="faq-icon text-[var(--ks-primary)] transition duration-300 font-bold text-lg">+</span>
						</div>
						<div class="faq-content max-h-0 overflow-hidden transition-all duration-300 ease-in-out">
							<p class="pt-3 text-xs md:text-sm text-[var(--ks-text-muted)] leading-relaxed">
								Sí, actualmente el proyecto es de código abierto y completamente gratuito para fines de desarrollo y auto-hospedaje. Cualquiera puede descargarlo y correrlo localmente.
							</p>
						</div>
					</div>

					<div class="faq-item border border-[var(--ks-border)] bg-[var(--ks-surface)] rounded-2xl p-5 cursor-pointer transition-all hover:border-[var(--ks-primary-muted)]">
						<div class="flex items-center justify-between">
							<h4 class="font-bold text-[var(--ks-text)] pr-4 text-sm md:text-base">¿Puedo personalizar los horarios de mi negocio?</h4>
							<span class="faq-icon text-[var(--ks-primary)] transition duration-300 font-bold text-lg">+</span>
						</div>
						<div class="faq-content max-h-0 overflow-hidden transition-all duration-300 ease-in-out">
							<p class="pt-3 text-xs md:text-sm text-[var(--ks-text-muted)] leading-relaxed">
								Totalmente. El sistema permite configurar los días laborales de la semana, junto con las horas de apertura y de cierre de cada día de forma independiente, así como desactivar días completos.
							</p>
						</div>
